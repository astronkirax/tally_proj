# Copy this file to ".env" and fill in what you need. The core app (HDFC parsing,
# reconciliation, red-flags, exports) works fully WITHOUT any key. A key adds:
#   - AI classification of the ambiguous "needs review" rows
#   - the generic AI parser, which reads ANY bank's statement (not just HDFC)

# DeepSeek (OpenAI-compatible). Get a key at https://platform.deepseek.com/ -> API Keys
DEEPSEEK_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
# For maximum quality (slower, ~12x cost) use: LLM_MODEL=deepseek-v4-pro

# --- Deferred to the persistence milestone (NOT needed for the local MVP) ---
# SUPABASE_URL=
# SUPABASE_KEY=
# DB_URL=
